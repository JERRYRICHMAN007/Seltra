# Copy to .env for local dev. On Vercel, add ALL vars below in
# Project Settings → Environment Variables (Production + Preview + Development).
#
# Supabase Dashboard → Settings → API:
#   VITE_SUPABASE_URL / SUPABASE_URL        = Project URL
#   VITE_SUPABASE_PUBLISHABLE_KEY /         = anon public key
#   SUPABASE_PUBLISHABLE_KEY
#   SUPABASE_SERVICE_ROLE_KEY               = service_role key (secret, server only)

# Client — required at BUILD time (VITE_ prefix)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server — required at RUNTIME for SSR
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
