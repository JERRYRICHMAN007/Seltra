# Copy to .env for local dev. On Vercel, add ALL vars below in
# Project Settings → Environment Variables (Production + Preview + Development).
#
# Supabase Dashboard → Settings → API:
#   VITE_SUPABASE_URL / SUPABASE_URL        = Project URL
#   VITE_SUPABASE_PUBLISHABLE_KEY /         = anon public key
#   SUPABASE_PUBLISHABLE_KEY
#   SUPABASE_SERVICE_ROLE_KEY               = service_role key (secret, server only)

# Client — also used at runtime on Vercel via SSR injection
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server — required at RUNTIME for SSR (must match VITE_* values above)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Seltra internal API (server-only — dashboard overview metrics)
SELTRA_API_BASE_URL=https://api.seltra.co
SELTRA_INTERNAL_API_KEY=
OPS_INTERNAL_API_KEY=
OPS_ACTOR=admin@seltra.co

# Moolre SMS (server-only — Messaging feature)
# X-API-VASKEY is required for SMS (not the same as MOOLRE_API_KEY)
MOOLRE_API_USER=
MOOLRE_API_KEY=
MOOLRE_SENDER_ID=Seltra
VAS_KEY=

# Resend email (server-only — Messaging feature)
RESEND_API_KEY=
RESEND_FROM=Seltra <careers@send.seltra.co>
RESEND_NOTIFY_TO=

# Vercel: after adding vars, redeploy. Supabase Auth → URL Configuration:
#   Site URL = https://YOUR-APP.vercel.app
#   Redirect URLs = https://YOUR-APP.vercel.app/**
